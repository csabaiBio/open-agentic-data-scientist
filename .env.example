# ============================================================
# Option A: AWS Bedrock (single API key for everything)
# ============================================================
# Get your key from: https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys.html
# This powers BOTH the planning/review agents (via LiteLLM) AND the coding agent (via Claude Code).
AWS_BEDROCK_API_KEY="your-bedrock-api-key"
AWS_REGION_NAME="us-east-1"

# ============================================================
# Option B: OpenRouter + Anthropic (original setup)
# ============================================================
# ANTHROPIC_API_KEY="your-key-here"      # For Claude Code coding agent
# OPENROUTER_API_KEY="your-key-here"     # For planning/review agents
# OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
# OR_SITE_URL="k-dense.ai"
# OR_APP_NAME="Agentic Data Scientist"

# ============================================================
# Model configuration
# ============================================================
# For Bedrock, use bedrock-prefixed names (e.g., "bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0")
# For OpenRouter, use provider-prefixed names (e.g., "google/gemini-2.5-pro")
# DEFAULT_MODEL="bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# CODING_MODEL="claude-sonnet-4-5-20250929"
# REVIEW_MODEL="bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0"

# Optional: Context7 API Key for enhanced documentation access
# CONTEXT7_API_KEY="your-key-here"

# Optional: Disable network access
# DISABLE_NETWORK_ACCESS=true