# ============================================================
# Option A: AWS Bedrock (single API key for everything)
# ============================================================
# Get your key from: https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys.html
# This powers BOTH the planning/review agents (via LiteLLM) AND the coding agent (via Claude Code).
AWS_BEDROCK_API_KEY="your-bedrock-api-key"
AWS_REGION_NAME="us-east-1"

# ============================================================
# Option C: Azure OpenAI Foundry (GPT models via Azure)
# ============================================================
# AZURE_API_KEY="your-azure-api-key"
# AZURE_API_BASE="https://<resource>.openai.azure.com/"
# AZURE_API_VERSION="2025-04-01-preview"   # optional, this is the default
# Use "azure/<deployment-name>" as model names (e.g., "azure/gpt-5.4")

# ============================================================
# Option D: Azure OpenAI Foundry (Claude models via Azure)
# ============================================================
# AZURE_ANTHROPIC_API_KEY="your-azure-api-key"  # can be same as GPT key
# AZURE_ANTHROPIC_URL="https://<azure-gateway-url>/"  # separate Claude endpoint
# Use "azure-anthropic/<deployment-name>" as model names (e.g., "azure-anthropic/claude-opus-4-7")

# ============================================================
# Option B: OpenRouter + Anthropic (original setup)
# ============================================================
# ANTHROPIC_API_KEY="your-key-here"      # For Claude Code coding agent
# OPENROUTER_API_KEY="your-key-here"     # For planning/review agents
# OPENROUTER_API_BASE="https://openrouter.ai/api/v1"
# OR_SITE_URL="k-dense.ai"
# OR_APP_NAME="Agentic Data Scientist"

# ============================================================
# Model configuration
# ============================================================
# For Bedrock, use bedrock-prefixed names (e.g., "bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0")
# For OpenRouter, use provider-prefixed names (e.g., "google/gemini-2.5-pro")
# DEFAULT_MODEL="bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# CODING_MODEL="claude-sonnet-4-5-20250929"
# REVIEW_MODEL="bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0"

# Optional: Context7 API Key for enhanced documentation access
# CONTEXT7_API_KEY="your-key-here"

# Optional: Projects directory location (default: ./projects)
# All project data, files, and metadata are stored here. Use absolute path for reliable access.
# PROJECTS_DIR="/path/to/projects"

# Optional: Disable network access
# DISABLE_NETWORK_ACCESS=true

# Optional: LangSmith tracing (https://smith.langchain.com)
# LANGSMITH_API_KEY="your-langsmith-api-key"
# LANGSMITH_PROJECT="agentic-data-scientist"   # defaults to "agentic-data-scientist"
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com" # set EU/self-hosted endpoint if needed

# Optional: checkpoint controls
# CHECKPOINT_EVENT_INTERVAL=10     # write progress event every N runtime events (min 1)
# CHECKPOINT_MAX_EVENTS=200        # keep last N checkpoint events in output/checkpoint.json
# CHECKPOINT_MAX_SUMMARIES=3       # keep last N checkpoint summaries in output/checkpoint.json

# Optional: human-in-the-loop controls
# HUMAN_IN_THE_LOOP=false          # set false to disable; defaults to true when unset/empty
# HUMAN_IN_THE_LOOP_TIMEOUT=300    # seconds to wait for user answer before continuing automatically

# Optional: backend logging (web mode)
# BACKEND_LOG_FILE="./web/backend/backend.log"  # if set, backend logs are written here
# BACKEND_LOG_LEVEL="INFO"                      # DEBUG | INFO | WARNING | ERROR
# BACKEND_LOG_MAX_BYTES=5242880                  # rotate at ~5MB by default
# BACKEND_LOG_BACKUP_COUNT=3                     # keep N rotated files